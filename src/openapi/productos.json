{
  "openapi": "3.1.0",
  "info": {
    "title": "NinjaAPI",
    "version": "1.0.0",
    "description": ""
  },
  "paths": {
    "/api/productos/listar": {
      "get": {
        "operationId": "producto_api_listar_productos",
        "summary": "Listar Productos",
        "parameters": [
          {
            "in": "query",
            "name": "busqueda",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Busqueda"
            },
            "required": false
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 100,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            },
            "required": false
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedProductoSchema"
                }
              }
            }
          }
        },
        "tags": ["Productos"],
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    },
    "/api/productos/actualizar/{producto_id}": {
      "put": {
        "operationId": "producto_api_actualizar_producto",
        "summary": "Actualizar Producto",
        "parameters": [
          {
            "in": "path",
            "name": "producto_id",
            "schema": {
              "title": "Producto Id",
              "type": "integer"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductoSchema"
                }
              }
            }
          }
        },
        "tags": ["Productos"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoUpdateSchema"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    },
    "/api/productos/eliminar/{producto_id}": {
      "delete": {
        "operationId": "producto_api_eliminar_producto",
        "summary": "Eliminar Producto",
        "parameters": [
          {
            "in": "path",
            "name": "producto_id",
            "schema": {
              "title": "Producto Id",
              "type": "integer"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "tags": ["Productos"],
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Input": {
        "properties": {
          "limit": {
            "default": 100,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "minimum": 0,
            "title": "Offset",
            "type": "integer"
          }
        },
        "title": "Input",
        "type": "object"
      },
      "PagedProductoSchema": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProductoSchema"
            },
            "title": "Items",
            "type": "array"
          },
          "count": {
            "title": "Count",
            "type": "integer"
          }
        },
        "required": ["items", "count"],
        "title": "PagedProductoSchema",
        "type": "object"
      },
      "ProductoSchema": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "ID"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "nombre": {
            "maxLength": 255,
            "title": "Nombre",
            "type": "string"
          },
          "precio": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Precio",
            "type": "string"
          },
          "cuenta": {
            "title": "Cuenta",
            "type": "integer"
          }
        },
        "required": ["created_at", "updated_at", "nombre", "precio", "cuenta"],
        "title": "ProductoSchema",
        "type": "object"
      },
      "ProductoUpdateSchema": {
        "properties": {
          "nombre": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Nombre"
          },
          "precio": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio"
          }
        },
        "title": "ProductoUpdateSchema",
        "type": "object"
      }
    },
    "securitySchemes": {
      "AuthBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "servers": []
}
